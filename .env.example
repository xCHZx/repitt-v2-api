PORT=3000

# Supabase PostgreSQL Connection String
DATABASE_URL="postgres://postgres:postgres@localhost:5432/repitt"

# JWT Secret
JWT_SECRET="super-secret-key-change-in-production"

SITE_URL=http://localhost:5173
FRONTEND_URL=https://app.repitt.com

# ----- Supabase -----
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key"
SYSTEM_BUCKET_NAME="RepittDev"

# ------ Emails --------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-smtp-user@smtp-brevo.com
BREVO_SMTP_KEY=your-brevo-smtp-key
MAIL_FROM_NAME=Repitt
MAIL_FROM_ADDRESS=no-reply@repitt.com
BREVO_API_KEY=your-brevo-api-key
BREVO_TEMPLATE_WELCOME_OWNER=2

# ------ Stripe --------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # Dashboard (prod) or `stripe listen` output (local)
STRIPE_PRICE_ID=price_...              # Price ID from Stripe Product Catalog
STRIPE_SUCCESS_URL=http://localhost:5173/empresa/planes/gracias
STRIPE_CANCEL_URL=http://localhost:5173/empresa/planes
